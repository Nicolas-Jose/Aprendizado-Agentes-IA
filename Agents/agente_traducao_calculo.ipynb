    "import os\n",
    "from langchain_core.messages import HumanMessage, SystemMessage, AIMessageChunk, AIMessage\n",
    "from langchain_openai import ChatOpenAI\n",
    "from langchain_core.tools import tool\n",
    "from langchain.agents import create_agent\n",
    "\n",
    "os.environ[\"OPENAI_API_KEY\"] = \"OPENAI_API_KEY_AQUI\"\n",
    "# LangSmith\n",
    "os.environ[\"LANGCHAIN_TRACING_V2\"] = \"true\"\n",
    "os.environ[\"LANGCHAIN_API_KEY\"] = \"LANGCHAIN_API_KEY_AQUI\"\n",
    "os.environ[\"LANGCHAIN_PROJECT\"] = \"pr-warmhearted-address-66\"\n",
    "\n",
    "llm = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0)\n",
    "llm_tradutor = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0.3)\n",
    "\n",
    "@tool\n",
    "def calculadora(expressao: str) -> str:\n",
    "    \"\"\"Ferramenta para realizar c脙隆lculos matem脙隆ticos.\"\"\"\n",
    "    try:\n",
    "        resultado = eval(expressao, {\"__builtins__\": {}}, {})\n",
    "        return f\"Resultado: {resultado}\"\n",
    "    except Exception as e:\n",
    "        return f\"Erro no c脙隆lculo: {str(e)}\"\n",
    "\n",
    "@tool\n",
    "def tradutor_tool(texto: str, idioma_destino: str = \"ingl脙陋s\") -> str:\n",
    "    \"\"\"Ferramenta para traduzir textos usando LLM interno.\"\"\"\n",
    "    try:\n",
    "        prompt = f\"Traduza o seguinte texto para {idioma_destino}. Retorne APENAS a tradu脙搂脙拢o:\\n\\n{texto}\"\n",
    "        response = llm_tradutor.invoke(prompt)\n",
    "        return f\"Tradu脙搂脙拢o: {response.content.strip()}\"\n",
    "    except Exception as e:\n",
    "        return f\"Erro na tradu脙搂脙拢o: {str(e)}\"\n",
    "\n",
    "CALCULADORA_PROMPT = \"\"\"\n",
    "Voc脙陋 脙漏 um assistente especializado em matem脙隆tica e c脙隆lculos.\n",
    "REGRA OBRIGAT脙鈥淩IA DE FORMATA脙鈥∶兤扥:\n",
    "Toda resposta DEVE seguir este formato exato:\n",
    "[Explica脙搂脙拢o detalhada do racioc脙颅nio matem脙隆tico, ordem de opera脙搂脙碌es e processo]\n",
    "[Linha em branco]\n",
    "[Resultado final claro e direto]\n",
    "SEMPRE use a ferramenta calculadora para fazer os c脙隆lculos e SEMPRE forne脙搂a explica脙搂脙拢o did脙隆tica antes do resultado.\n",
    "\"\"\"\n",
    "\n",
    "llm_calculo = ChatOpenAI(model=\"gpt-4o-mini\", temperature=0).bind_tools(\n",
    "    [calculadora],\n",
    "    tool_choice=\"required\"\n",
    ")\n",
    "\n",
    "calculadora_agent = create_agent(\n",
    "    llm_calculo,\n",
    "    tools=[calculadora],\n",
    "    system_prompt=CALCULADORA_PROMPT\n",
    ")\n",
    "\n",
    "# Sub-agente 2: Especialista em Tradu脙搂脙拢o\n",
    "TRADUTOR_PROMPT = \"\"\"\n",
    "Voc脙陋 脙漏 um assistente especializado em tradu脙搂脙拢o de idiomas.\n",
    "\n",
    "REGRA OBRIGAT脙鈥淩IA DE FORMATA脙鈥∶兤扥:\n",
    "Toda resposta DEVE seguir este formato exato:\n",
    "\n",
    "[Explica脙搂脙拢o sobre a express脙拢o/palavra, contexto cultural ou lingu脙颅stico]\n",
    "\n",
    "[Linha em branco]\n",
    "\n",
    "[Resultado da tradu脙搂脙拢o claro e direto]\n",
    "\n",
    "Exemplo:\n",
    "Pergunta: \"Traduza 'Bom dia' para franc脙陋s\"\n",
    "\n",
    "Resposta:\n",
    "A express脙拢o \"Bom dia\" 脙漏 uma sauda脙搂脙拢o matinal comum em portugu脙陋s. Em franc脙陋s, a sauda脙搂脙拢o equivalente combina \"bon\" (bom) com \"jour\" (dia).\n",
    "\n",
    "A tradu脙搂脙拢o de \"Bom dia\" para franc脙陋s 脙漏 \"Bonjour\".\n",
    "\n",
    "SEMPRE use a ferramenta de tradu脙搂脙拢o e SEMPRE forne脙搂a contexto antes do resultado.\n",
    "\"\"\"\n",
    "\n",
    "tradutor_agent = create_agent(\n",
    "    llm_tradutor,\n",
    "    tools=[tradutor_tool],\n",
    "    system_prompt=TRADUTOR_PROMPT\n",
    ")\n",
    "\n",
    "\n",
    "@tool\n",
    "def realizar_calculo(solicitacao: str) -> str:\n",
    "    \"\"\"Realiza c脙隆lculos matem脙隆ticos com explica脙搂脙拢o did脙隆tica.\"\"\"\n",
    "    result = calculadora_agent.invoke({\n",
    "        \"messages\": [{\"role\": \"user\", \"content\": solicitacao}]\n",
    "    })\n",
    "    return result[\"messages\"][-1].content\n",
    "\n",
    "\n",
    "@tool\n",
    "def realizar_traducao(solicitacao: str) -> str:\n",
    "    \"\"\"Traduz textos entre idiomas com contexto explicativo.\n",
    "    \n",
    "    Use quando o usu脙隆rio quiser traduzir palavras, frases ou textos\n",
    "    para outros idiomas.\n",
    "    \n",
    "    Entrada: Solicita脙搂脙拢o de tradu脙搂脙拢o em linguagem natural (ex: 'traduza hello para portugu脙陋s')\n",
    "    \"\"\"\n",
    "    result = tradutor_agent.invoke({\n",
    "        \"messages\": [{\"role\": \"user\", \"content\": solicitacao}]\n",
    "    })\n",
    "    return result[\"messages\"][-1].content\n",
    "\n",
    "SUPERVISOR_PROMPT = \"\"\"\n",
    "Voc脙陋 脙漏 um assistente inteligente que coordena especialistas em matem脙隆tica e tradu脙搂脙拢o.\n",
    "\n",
    "Voc脙陋 tem acesso a dois especialistas:\n",
    "1. Especialista em C脙隆lculos - para todas as opera脙搂脙碌es matem脙隆ticas\n",
    "2. Especialista em Tradu脙搂脙拢o - para traduzir textos entre idiomas\n",
    "\n",
    "IMPORTANTE:\n",
    "- Quando o usu脙隆rio pedir c脙隆lculos, use o especialista em c脙隆lculos\n",
    "- Quando o usu脙隆rio pedir tradu脙搂脙碌es, use o especialista em tradu脙搂脙拢o\n",
    "- Se a solicita脙搂脙拢o envolver ambos, use os dois em sequ脙陋ncia\n",
    "- Sempre retorne a resposta completa dos especialistas, mantendo o formato explicativo\n",
    "\n",
    "Voc脙陋 deve apenas coordenar e passar as solicita脙搂脙碌es para os especialistas corretos.\n",
    "Os especialistas j脙隆 seguem o formato correto de resposta (explica脙搂脙拢o + resultado).\n",
    "\"\"\"\n",
    "\n",
    "supervisor_agent = create_agent(\n",
    "    llm,\n",
    "    tools=[realizar_calculo, realizar_traducao],\n",
    "    system_prompt=SUPERVISOR_PROMPT\n",
    ")\n",
    "def run_agent(user_input: str) -> str:\n",
    "    \"\"\"Executa o supervisor e retorna a resposta final.\"\"\"\n",
    "    messages = [{\"role\": \"user\", \"content\": user_input}]\n",
    "    result = supervisor_agent.invoke({\"messages\": messages})\n",
    "    return result[\"messages\"][-1].content\n",
    "\n",
    "\n",
    "def run_agent_stream(user_input: str) -> str:\n",
    "    \"\"\"Executa o supervisor com streaming palavra por palavra.\"\"\"\n",
    "    messages = [{\"role\": \"user\", \"content\": user_input}]\n",
    "    \n",
    "    resposta_final = \"\"\n",
    "    \n",
    "    # stream_mode=\"messages\" captura cada token individual\n",
    "    for event in supervisor_agent.stream({\"messages\": messages}, stream_mode=\"messages\"):\n",
    "        msg, metadata = event\n",
    "        \n",
    "        # Streaming de chunks (palavra por palavra)\n",
    "        if isinstance(msg, AIMessageChunk) and msg.content:\n",
    "            print(msg.content, end=\"\", flush=True)\n",
    "            resposta_final += msg.content\n",
    "    \n",
    "    \n"
   ]
  },
